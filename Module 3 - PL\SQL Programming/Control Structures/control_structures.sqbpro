<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="/home/aritrachats/Cognizant-Java-FSE/Module 3 - PL\SQL Programming/Control Structures/bank.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1495"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><current_table name="4,4:mainbank"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="bank" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_"><sort/><column_widths><column index="1" value="90"/><column index="2" value="123"/><column index="3" value="33"/><column index="4" value="97"/><column index="5" value="41"/><column index="6" value="83"/><column index="7" value="62"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="create_db">CREATE TABLE bank (
	CustomerID INT PRIMARY KEY,
	CustomerName VARCHAR(100),
	Age INT CHECK (Age &gt;= 18),
	InterestRate DECIMAL(4,2) CHECK (InterestRate &gt;= 0),
	IsVIP BOOLEAN,
	DueDate DATE,
	Balance DECIMAL (10,2)
);</sql><sql name="populate_db">INSERT INTO bank
(CustomerID, CustomerName, Age, InterestRate, DueDate, Balance)
VALUES
(101, 'Amit Sharma',      25, 4.50, '2026-07-10',  8500.00),
(102, 'Priya Singh',      34, 5.25, '2026-08-15', 15000.00),
