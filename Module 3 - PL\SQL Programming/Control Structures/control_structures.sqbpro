(115, 'Manoj Iyer',       66, 5.90, '2026-12-20', 27500.00);</sql><sql name="discounted_interest_rate">SELECT *, (0.99 * InterestRate) AS DiscountedRate FROM bank WHERE age &gt; 60</sql><sql name="isVIP">SELECT *, CASE
			WHEN balance &gt;= 10000 THEN 'TRUE'
			ELSE 'FALSE'
		END AS IsVIP 
FROM bank; </sql><sql name="SQL 6">SELECT *, 'Dear ' || CustomerName || ', your loan amount of ' || Balance || ' is due by ' || DueDate AS Message FROM bank WHERE JULIANDAY(DueDate) - JULIANDAY('now') BETWEEN 0 AND 30;</sql><current_tab id="4"/></tab_sql></sqlb_project>
